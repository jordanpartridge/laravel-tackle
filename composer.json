{
    "name": "jordandalton/laravel-tackle",
    "description": "An interactive, terminal-based AI coding assistant for Laravel \u2014 a Claude Code native to your Laravel app.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "ai",
        "coding-assistant",
        "artisan"
    ],
    "authors": [
        {
            "name": "Jordan Dalton",
            "email": "jordan.dalton@ymail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0 || ^13.0",
        "laravel/ai": "^0.1 || ^0.3",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^10.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Tackle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tackle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "pint": "./vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tackle\\TackleServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}